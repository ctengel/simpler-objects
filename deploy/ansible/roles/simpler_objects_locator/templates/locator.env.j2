{{ ansible_managed | comment }}
# Generated by Ansible — edits will be overwritten on the next playbook run.

OBJECT_SERVERS={{ locator_object_servers | join(',') }}
WORKERS={{ locator_workers }}
PORT={{ locator_port }}
{% if simpler_objects_cluster_secret is defined %}
CLUSTER_SECRET={{ simpler_objects_cluster_secret }}
{% endif %}
{% if locator_auth_clients is defined %}
AUTH_CONFIG={{ simpler_objects_config_dir }}/auth.toml
{% endif %}
{% if locator_signed_url_ttl is defined %}
SIGNED_URL_TTL={{ locator_signed_url_ttl }}
{% endif %}
{% if tls_ca_src is defined %}
CA_BUNDLE={{ simpler_objects_tls_dir }}/ca.pem
{% endif %}
{% if tls_certfile_src is defined %}
UVICORN_TLS=--ssl-certfile {{ simpler_objects_tls_dir }}/host.crt --ssl-keyfile {{ simpler_objects_tls_dir }}/host.key
{% endif %}
