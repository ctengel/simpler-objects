{{ ansible_managed | comment }}
# Drop-in for simpler-objects-object-server@{{ instance.name }}.service.
# Redirects the unit's mount + ReadWritePaths from the
# /srv/simpler-objects/<instance> convention to the path declared in
# inventory. See deploy/systemd/README.md "Non-standard mount paths".
#
# The empty first line of each directive is required: without it systemd
# *appends* to the base unit's value, leaving both the original and the
# override active.

[Unit]
RequiresMountsFor=
RequiresMountsFor={{ instance.object_directory }}

[Service]
ReadWritePaths=
ReadWritePaths={{ instance.object_directory }}
