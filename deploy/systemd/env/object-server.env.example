# Example env file for simpler-objects-object-server.service.
# Copy this to ~/.config/simpler-objects/object-server.env and edit.
# A RequiresMountsFor= drop-in (created by Ansible or manually via
# `systemctl --user edit simpler-objects-object-server`) should point
# at the same mount path that contains OBJECT_DIRECTORY.

# Path the object server treats as the bucket parent directory.
# The storage device must be mounted and this directory owned by the service user.
OBJECT_DIRECTORY=/mnt/extusb-a/simpler-objects/data

# Set to any non-empty string to disable PUTs on this node (read-only mirror).
READ_ONLY=

# uvicorn worker count. The unit file sets WORKERS=1 by default; uncomment and
# raise toward CPU count on a busy node — the on-disk flock + O_CREAT|O_EXCL
# semantics in object_server.py make multi-worker safe.
# WORKERS=1

# Port the object server listens on. The locator's OBJECT_SERVERS must reach
# it at this port. Unit default is 29171.
# PORT=29171

# --- Security (all optional; see README "Auth and TLS") --------------------

# Shared cluster HMAC secret. When set, object/bucket requests must carry a
# valid ?exp=&sig= signature minted by the locator or replicator. Must match
# the locator's value. Generate: openssl rand -hex 32. Keep this file 600.
# CLUSTER_SECRET=

# Serve HTTPS. Unset/empty = plain HTTP.
# UVICORN_TLS=--ssl-certfile /home/svc-user/.config/simpler-objects/tls/host.crt --ssl-keyfile /home/svc-user/.config/simpler-objects/tls/host.key
