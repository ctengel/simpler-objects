# Example env file for simpler-objects-object-server@<instance>.service.
# Copy this to /etc/simpler-objects/object-server-<instance>.env (mode 0640,
# owned by root:simpler-objects) and edit. The <instance> token must match
# the systemctl instance name, e.g. /etc/simpler-objects/object-server-disk1.env
# for `systemctl start simpler-objects-object-server@disk1.service`.

# Path the object server treats as the bucket parent. By convention this is
# /srv/simpler-objects/<instance> and the storage device must be mounted
# there — the unit file's RequiresMountsFor= encodes the same path.
OBJECT_DIRECTORY=/srv/simpler-objects/disk1

# Set to any non-empty string to disable PUTs on this node (read-only mirror).
READ_ONLY=

# uvicorn worker count. Default 1 in the unit file. Raise toward CPU count on
# a busy node — the on-disk flock + O_CREAT|O_EXCL semantics in object_server.py
# make multi-worker safe.
WORKERS=1

# Port the object server listens on. The locator's OBJECT_SERVERS must reach it
# at this port.
PORT=29171
