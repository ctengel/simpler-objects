# Example env file for simpler-objects-async-replicate@<bucket>.service.
# Copy this to /etc/simpler-objects/async-replicate.env (mode 0640,
# owned by root:simpler-objects). Per-bucket overrides go in
# /etc/simpler-objects/async-replicate-<bucket>.env using the same syntax.

# URL of the locator API. Trailing slash required.
LOCATOR_URL=http://localhost:29164/

# Desired replica count for each object. async_replicate will create up to
# (REPLICAS - current-replica-count) additional copies per run.
REPLICAS=2
