# Example env file for simpler-objects-async-replicate.service.
# Copy this to ~/.config/simpler-objects/async-replicate.env and edit.

# URL of the locator API. Trailing slash required. Unit default is
# http://localhost:29164/ — set this if the locator is on another host.
# LOCATOR_URL=http://localhost:29164/

# Default replica count. async_replicate will create up to
# (REPLICAS - current-replica-count) additional copies per run.
# Unit default is 2.
# REPLICAS=2

# Space-separated list of buckets to replicate. Required — no default.
BUCKETS=photos backups

# Per-bucket replica override: REPLICAS_<UPPERCASE_BUCKET>=N
# If omitted, REPLICAS above applies. Example:
# REPLICAS_BACKUPS=3
