# Example env file for simpler-objects async-replicate services.
# Copy this to /etc/simpler-objects/async-replicate.env (mode 0640,
# owned by root:simpler-objects).

# URL of the locator API. Trailing slash required.
LOCATOR_URL=http://localhost:29164/

# Default replica count. async_replicate will create up to
# (REPLICAS - current-replica-count) additional copies per run.
REPLICAS=2

# Space-separated list of buckets to replicate.
BUCKETS=photos backups

# Per-bucket replica override: REPLICAS_<UPPERCASE_BUCKET>=N
# If omitted, REPLICAS above applies. Example:
# REPLICAS_BACKUPS=3
