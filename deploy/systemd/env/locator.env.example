# Example env file for simpler-objects-locator.service.
# Copy this to ~/.config/simpler-objects/locator.env and edit.

# Comma-separated list of object server URLs. Trailing slashes are required
# (the locator concatenates paths directly onto them).
OBJECT_SERVERS=http://pi1.lan:29171/,http://pi2.lan:29171/

# uvicorn worker count. Unit default is 1; the locator is stateless and
# trivially safe with multiple workers.
# WORKERS=1

# Port the locator listens on. Unit default is 29164.
# PORT=29164

# --- Security (all optional; see README "Auth and TLS") --------------------

# Shared cluster HMAC secret for signing object-server URLs. Must match the
# object servers' and replicator's value. Generate: openssl rand -hex 32
# Required if AUTH_CONFIG is set. Keep this file chmod 600.
# CLUSTER_SECRET=

# Path to the client API-key/permission TOML (chmod 600). Enables client
# authentication; requires CLUSTER_SECRET. Use a full path — systemd does
# not expand specifiers like %E inside env files.
# AUTH_CONFIG=/home/svc-user/.config/simpler-objects/auth.toml

# Seconds a signed URL stays valid (default 900). Only the start of a
# request must land inside the window, so large transfers are unaffected.
# SIGNED_URL_TTL=900

# PEM bundle to verify the object servers' HTTPS certs (e.g. the private
# CA). Unset = system trust store.
# CA_BUNDLE=/home/svc-user/.config/simpler-objects/tls/ca.pem

# Serve HTTPS. Unset/empty = plain HTTP.
# UVICORN_TLS=--ssl-certfile /home/svc-user/.config/simpler-objects/tls/host.crt --ssl-keyfile /home/svc-user/.config/simpler-objects/tls/host.key
